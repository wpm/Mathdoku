{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mathdoku Designer",
  "mainBinaryName": "mathdoku-designer",
  "version": "0.1.0",
  "identifier": "com.wpmcneill.mathdoku.designer",
  "build": {
    "beforeDevCommand": {
      "script": "cd .. && trunk serve",
      "wait": false,
      "dev": true
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "trunk build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "",
        "width": 720,
        "height": 760,
        "minWidth": 640,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["mathdoku"],
        "name": "Mathdoku Puzzle",
        "description": "Mathdoku puzzle file",
        "mimeType": "application/x-mathdoku",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/wpm/Mathdoku/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzNkExNkU2NUZFQjc2RTUKUldUbGR1dGY1aFpxOHpIcmYwSDdlK2R6YkZVR2JhcnQyUGtrV25EZ1ZkTE5ucHI2Mzc1QURQYkYK"
    }
  }
}
